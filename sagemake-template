#!/usr/bin/env python3
"""
sagemake — Build system for {{ PROJECT_NAME }}

{{ PROJECT_DESCRIPTION }}

Usage:
    ./sagemake [command] [flags]

Commands:
    build      Run the full build pipeline
    test       Run the test suite
    install    Install built artifacts
    clean      Remove build artifacts
    all        Run build then test
"""

import hashlib
import os
import shutil
import subprocess
import sys
from pathlib import Path

# ── ANSI helpers ──────────────────────────────────────────────────────────────

RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"


def banner(title: str) -> None:
    width = 60
    line = f"{CYAN}{'═' * width}{RESET}"
    print(f"\n{line}")
    print(f"{CYAN}  {BOLD}{title}{RESET}")
    print(f"{line}\n")


def section(title: str) -> None:
    print(f"  {CYAN}→{RESET} {title}")


def step(msg: str) -> None:
    print(f"    {msg} ... ", end="", flush=True)


def ok() -> None:
    print(f"{GREEN}✓ done{RESET}")


def fail() -> None:
    print(f"{RED}✗ failed{RESET}")
    sys.exit(1)


def step_ok(detail: str) -> None:
    print(f"{GREEN}✓ {detail}{RESET}")


def step_fail(detail: str) -> None:
    print(f"{RED}✗ {detail}{RESET}")
    sys.exit(1)


def step_warn(detail: str) -> None:
    print(f"{YELLOW}! {detail}{RESET}")


def run(cmd: list[str], **kwargs) -> subprocess.CompletedProcess:
    """Run a command and return the result."""
    try:
        return subprocess.run(cmd, check=True, **kwargs)
    except subprocess.CalledProcessError as e:
        step_fail(f"command failed with exit code {e.returncode}: {' '.join(cmd)}")
    except FileNotFoundError:
        step_fail(f"command not found: {cmd[0]}")


# ── Configuration ─────────────────────────────────────────────────────────────

ROOT = Path(__file__).resolve().parent
BUILD_DIR = ROOT / "build"
SRC_DIR = ROOT / "src"
TEST_DIR = ROOT / "tests"
BINARY_NAME = "{{ BINARY_NAME }}"


# ── Helpers ───────────────────────────────────────────────────────────────────

def get_source_hash(directory: Path) -> str:
    """Calculate a single SHA-256 hash for all files in a directory recursively."""
    if not directory.exists():
        return ""
    hasher = hashlib.sha256()
    for filepath in sorted(directory.rglob("*"), key=lambda p: p.as_posix()):
        if filepath.is_file():
            # Add path length and path with null byte delimiter to prevent collision
            path_bytes = filepath.relative_to(directory).as_posix().encode("utf-8")
            hasher.update(len(path_bytes).to_bytes(8, byteorder='big'))
            hasher.update(path_bytes)
            hasher.update(b"\0")

            try:
                content = filepath.read_bytes()
                # Add content length to prevent collision
                hasher.update(len(content).to_bytes(8, byteorder='big'))
                hasher.update(content)
            except Exception as e:
                step_fail(f"failed to read {filepath} for hashing: {e}")
    return hasher.hexdigest()


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_build(args: list[str]) -> None:
    banner("build — {{ PROJECT_NAME }}")
    check_dependencies()
    section("Compilation")

    # Incremental build check
    current_hash = get_source_hash(SRC_DIR)
    hash_file = BUILD_DIR / ".build_hash"
    binary_file = BUILD_DIR / BINARY_NAME
    if hash_file.exists() and hash_file.read_text().strip() == current_hash and current_hash != "" and binary_file.exists():
        step_ok("up-to-date")
        return

    step("compiling source")
    BUILD_DIR.mkdir(parents=True, exist_ok=True)
    # TODO: Add your build logic here
    # Example: run(["gcc", "-o", str(BUILD_DIR / BINARY_NAME), str(SRC_DIR / "main.c")])
    ok()

    # Save the new hash after a successful build
    hash_file.write_text(current_hash)


def cmd_test(args: list[str]) -> None:
    banner("test — {{ PROJECT_NAME }}")
    # TODO: Add your test logic here
    # Example: run(["pytest", str(TEST_DIR)])
    step_ok("all tests passed")


def cmd_install(args: list[str]) -> None:
    banner("install — {{ PROJECT_NAME }}")
    # On Windows, /usr/local/bin may not exist or make sense; defaulting to a standard prefix
    install_dir = Path("/usr/local/bin") if os.name != "nt" else Path(os.environ.get("APPDATA", "C:/ProgramData")) / "{{ PROJECT_NAME }}"
    target = install_dir / BINARY_NAME
    step(f"installing to {target}")
    if not (BUILD_DIR / BINARY_NAME).exists():
        step_fail(f"{BINARY_NAME} not built — run build first")
    try:
        install_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(BUILD_DIR / BINARY_NAME, target)
        if os.name != "nt":
            target.chmod(0o755)
    except PermissionError:
        step_fail("permission denied (try running as Administrator/root)")
    except Exception as e:
        step_fail(f"installation failed: {e}")
    step_ok(f"installed {BINARY_NAME}")


def cmd_clean(args: list[str]) -> None:
    banner("clean — {{ PROJECT_NAME }}")
    section("Removing build artifacts")
    step(f"removing {BUILD_DIR}")
    if BUILD_DIR.exists():
        try:
            shutil.rmtree(BUILD_DIR)
        except Exception as e:
            step_fail(f"failed to remove build dir: {e}")
    ok()


def cmd_all(args: list[str]) -> None:
    cmd_build(args)
    cmd_test(args)


# ── Dependency check ──────────────────────────────────────────────────────────

def check_dependencies() -> None:
    """Verify required tools are available on PATH."""
    section("Dependencies")
    required = {{ DEPENDENCIES }}
    missing = []
    for dep in required:
        step(f"checking {dep}")
        if shutil.which(dep) is None:
            missing.append(dep)
            print(f"{RED}✗ not found{RESET}")
        else:
            ok()
    if missing:
        step_fail(f"missing: {', '.join(missing)}")


# ── CLI dispatch ──────────────────────────────────────────────────────────────

def main() -> None:
    commands: dict[str, callable] = {
        "build": cmd_build,
        "test": cmd_test,
        "install": cmd_install,
        "clean": cmd_clean,
        "all": cmd_all,
    }

    if len(sys.argv) < 2 or sys.argv[1] not in commands:
        banner("{{ PROJECT_NAME }} — sagemake")
        print(f"  Usage:  ./sagemake {'|'.join(commands.keys())}")
        print()
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]
    commands[cmd](args)


if __name__ == "__main__":
    main()
